{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      {{PERMISSION_ENTRIES}}
    ]
  },
  "hooks": {
    "PreToolUse": [
      {{PRETOOLUSE_HOOKS}}
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {{FORMAT_HOOK}}
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Before finishing, check: (1) Are there failing tests? If so, mention them. (2) Are there uncommitted changes? If so, ask if the user wants to commit."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "jq -r '\"[\\(.model.display_name // \"claude\")] ctx: \\(.context_window.used_percentage // 0 | floor)%\"'"
  }
}
